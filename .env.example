# Jennifer Slade — env var template (set in Vercel dashboard, not committed)
#
# Lead-capture routing for /api/private-access. All variables are optional.
# Graceful degradation:
#   - If CRM_WEBHOOK_URL is set, the lead POSTs there.
#   - If RESEND_API_KEY + JENNIFER_NOTIFICATION_EMAIL are set, the lead also
#     gets emailed (in addition to the webhook).
#   - If neither is set, the API returns 200 and logs the lead to the Vercel
#     function output. Submissions are never lost — but the inbox needs at
#     least one of these wired up for them to surface anywhere.

# CRM webhook (Zapier, KVCore, Compass, LionDesk, HubSpot, etc.)
CRM_WEBHOOK_URL=

# Resend email dispatch (preferred over SendGrid — easier setup, free tier)
# https://resend.com — verify the jenniferslade.com domain before sending.
RESEND_API_KEY=
JENNIFER_NOTIFICATION_EMAIL=jen@rundogreg.com
